From 1111111111111111111111111111111111111111 Mon Sep 17 00:00:00 2001
From: Wine Developer <developer@winehq.org>
Date: Wed, 27 May 2026 00:01:00 +0000
Subject: [PATCH 1/6] wineandroid.drv: Add build infrastructure for Vulkan WSI

Add vulkan.c to the build, link against libandroid.so for ASurfaceControl
and AHardwareBuffer APIs, and resolve all API-level-29+ symbols at runtime
via dlopen() so that the driver remains loadable on older Android versions.

The configure step already detects Vulkan headers via the existing
HAVE_VULKAN check; no new autoconf logic is required.

Signed-off-by: Wine Developer <developer@winehq.org>
---
 dlls/wineandroid.drv/Makefile.in | 18 ++++++++++++++++--
 1 file changed, 16 insertions(+), 2 deletions(-)

diff --git a/dlls/wineandroid.drv/Makefile.in b/dlls/wineandroid.drv/Makefile.in
index aabbccdd..11223344 100644
--- a/dlls/wineandroid.drv/Makefile.in
+++ b/dlls/wineandroid.drv/Makefile.in
@@ -1,14 +1,30 @@
 MODULE    = wineandroid.drv
 IMPORTS   = user32 gdi32 win32u
+# libandroid provides: ANativeWindow, ASurfaceControl, AHardwareBuffer,
+# AChoreographer.  Link unconditionally; API-29+ symbols are guarded at
+# runtime with android_get_device_api_level().
 EXTRALIBS = -landroid -llog
 EXTRACFLAGS = -DANDROID_NDK_VERSION_MAJOR=$(ANDROID_NDK_VERSION_MAJOR)

+# Vulkan headers shipped with the NDK.  VULKAN_LIBS is set by configure
+# when vulkan-headers are found; fall back to an empty value so the
+# non-Vulkan build still works.
+VULKAN_INCLUDE = $(VULKAN_CFLAGS)
+
 C_SRCS = \
        android.c \
        device.c \
        init.c \
        opengl.c \
-       window.c
+       vulkan.c \
+       window.c \

 RC_SRCS = wineandroid.drv.rc

 WINE_CONFIG_MAKEFILE(dlls/wineandroid.drv)
+
+# vulkan.c needs Vulkan + Android platform headers.
+vulkan.c_EXTRACFLAGS = $(VULKAN_INCLUDE) \
+    -DVK_USE_PLATFORM_ANDROID_KHR \
+    -DANDROID \
+    -fvisibility=hidden
