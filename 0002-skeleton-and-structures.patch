+/* ------------------------------------------------------------------ *
+ *  Runtime NDK symbol table (API >= 29)                               *
+ *                                                                     *
+ *  All symbols are resolved once at first use via                     *
+ *  android_resolve_sc_syms().  Callers must check the 'available'     *
+ *  flag before calling into any of these pointers.                    *
+ * ------------------------------------------------------------------ */
+
+struct android_sc_funcs
+{
+    /* Availability flag: set to TRUE when all symbols resolved OK     */
+    BOOL available;
+
+    /* --- ASurfaceControl ------------------------------------------ */
+    ASurfaceControl *(*ASurfaceControl_createFromWindow)(
+            ANativeWindow *parent, const char *debug_name);
+    ASurfaceControl *(*ASurfaceControl_create)(
+            ASurfaceControl *parent, const char *debug_name);
+    void (*ASurfaceControl_release)(ASurfaceControl *sc);
+
+    /* --- ASurfaceTransaction -------------------------------------- */
+    ASurfaceTransaction *(*ASurfaceTransaction_create)(void);
+    void (*ASurfaceTransaction_delete)(ASurfaceTransaction *txn);
+    void (*ASurfaceTransaction_apply)(ASurfaceTransaction *txn);
+
+    void (*ASurfaceTransaction_setBuffer)(
+            ASurfaceTransaction *txn, ASurfaceControl *sc,
+            AHardwareBuffer *buf, int acquire_fence_fd);
+    void (*ASurfaceTransaction_setGeometry)(
+            ASurfaceTransaction *txn, ASurfaceControl *sc,
+            const ARect src, const ARect dst, int32_t transform);
+    void (*ASurfaceTransaction_setVisibility)(
+            ASurfaceTransaction *txn, ASurfaceControl *sc, int8_t vis);
+    void (*ASurfaceTransaction_setZOrder)(
+            ASurfaceTransaction *txn, ASurfaceControl *sc, int32_t z);
+    void (*ASurfaceTransaction_setFrameTimeline)(       /* API 31+    */
+            ASurfaceTransaction *txn, int64_t vsync_id);
+    void (*ASurfaceTransaction_setOnComplete)(
+            ASurfaceTransaction *txn,
+            void *ctx,
+            void (*cb)(void *ctx, ASurfaceTransactionStats *stats));
+    void (*ASurfaceTransaction_setOnCommit)(            /* API 31+    */
+            ASurfaceTransaction *txn,
+            void *ctx,
+            void (*cb)(void *ctx, ASurfaceTransactionStats *stats));

+    /* --- ASurfaceTransactionStats --------------------------------- */
+    int64_t (*ASurfaceTransactionStats_getLatchTime)(
+            ASurfaceTransactionStats *stats);
+    int (*ASurfaceTransactionStats_getPresentFenceFd)(
+            ASurfaceTransactionStats *stats);
+    int (*ASurfaceTransactionStats_getReleaseFenceFd)(
+            ASurfaceTransactionStats *stats,
+            ASurfaceControl *sc);
+
+    /* --- AHardwareBuffer ------------------------------------------ */
+    int  (*AHardwareBuffer_allocate)(
+            const AHardwareBuffer_Desc *desc, AHardwareBuffer **buf);
+    void (*AHardwareBuffer_release)(AHardwareBuffer *buf);
+    void (*AHardwareBuffer_describe)(
+            const AHardwareBuffer *buf, AHardwareBuffer_Desc *desc);
+
+    /* --- AChoreographer ------------------------------------------- */
+    AChoreographer *(*AChoreographer_getInstance)(void);
+    void (*AChoreographer_postVsyncCallback)(        /* API 30+      */
+            AChoreographer *choreographer,
+            AChoreographer_vsyncCallback callback,
+            void *data);
+    int64_t (*AChoreographer_getFrameDeadline)(      /* API 29+      */
+            AChoreographer *choreographer);
+};

+extern struct android_sc_funcs sc_funcs;
+BOOL android_resolve_sc_syms(void);
+
+/* ------------------------------------------------------------------ *
+ *  Per-buffer slot                                                    *
+ * ------------------------------------------------------------------ */
+#define WINE_VK_MAX_SWAPCHAIN_IMAGES 4

+struct wine_vk_buffer
+{
+    AHardwareBuffer *ahb;          /* Android native buffer                */
+    VkImage          vk_image;     /* Imported VkImage (AHB-backed)        */
+    VkDeviceMemory   vk_memory;    /* Device memory bound to vk_image      */
+    VkImageView      vk_view;      /* Convenience view (RGBA8, 2D)         */
+
+    int              release_fence_fd; /* SurfaceFlinger → us fence        */
+    BOOL             acquired;     /* TRUE while Wine app holds this slot  */
+};
+
+/* ------------------------------------------------------------------ *
+ *  Per-surface (= per HWND) state                                     *
+ * ------------------------------------------------------------------ */
+struct wine_vk_surface
+{
+    /* Android presentation layer */
+    ASurfaceControl *sc;           /* SurfaceFlinger surface control       */
+    ANativeWindow   *fallback_win; /* Used when API < 29                   */
+    VkSurfaceKHR     vk_surface;   /* Host VkSurfaceKHR (ANW path only)    */
+
+    /* Swapchain images */
+    struct wine_vk_buffer buffers[WINE_VK_MAX_SWAPCHAIN_IMAGES];
+    uint32_t              num_buffers;
+    uint32_t              width, height;
+    VkFormat              format;
+    VkDevice              device;
+
+    /* Vsync / presentation timing */
+    AChoreographer *choreographer;
+    int64_t         next_vsync_id;      /* set by choreographer callback   */
+    int64_t         next_vsync_deadline;

+    /* Concurrency */
+    pthread_mutex_t lock;
+    pthread_cond_t  buffer_released;   /* signalled from complete callback */

+    /* Linkage */
+    HWND            hwnd;
+    struct list     entry;             /* wine_vk_surface_list             */
+};
+
+/* Exported from vulkan.c */
+const struct vulkan_driver_funcs *get_vulkan_driver(UINT version);
+
 /* window.c */
 extern BOOL ANDROID_CreateWindow( HWND hwnd );

diff --git a/dlls/wineandroid.drv/vulkan.c b/dlls/wineandroid.drv/vulkan.c
new file mode 100644
index 00000000..aabbccdd
--- /dev/null
+++ b/dlls/wineandroid.drv/vulkan.c
@@ -0,0 +1,310 @@
+/*
+ * wineandroid.drv - Vulkan WSI
+ *
+ * High-performance swapchain backend:
+ *   ASurfaceControl + AHardwareBuffer + sync_fd pipeline
+ *
+ * Copyright 2026 Wine Project
+ *
+ * This library is free software; you can redistribute it and/or
+ * modify it under the terms of the GNU Lesser General Public
+ * License as published by the Free Software Foundation; either
+ * version 2.1 of the License, or (at your option) any later version.
+ */
+
+#include "config.h"
+
+#include <dlfcn.h>
+#include <errno.h>
+#include <pthread.h>
+#include <string.h>
+#include <unistd.h>
+
+#include <android/api-level.h>
+#include <android/hardware_buffer.h>
+#include <android/native_window.h>
+#include <android/surface_control.h>
+#include <android/choreographer.h>
+
+#define VK_USE_PLATFORM_ANDROID_KHR
+#include <vulkan/vulkan.h>
+
+#include "android.h"
+#include "wine/debug.h"
+#include "wine/list.h"
+
+WINE_DEFAULT_DEBUG_CHANNEL(vulkan);
+
+/* ------------------------------------------------------------------ *
+ *  Global state                                                       *
+ * ------------------------------------------------------------------ */
+
+/* Runtime-resolved NDK symbols (API 29+). */
+struct android_sc_funcs sc_funcs;
+
+/* HWND → wine_vk_surface lookup list, protected by surface_list_lock. */
+static struct list   surface_list      = LIST_INIT(surface_list);
+static pthread_mutex_t surface_list_lock = PTHREAD_MUTEX_INITIALIZER;
+
+/* Vulkan host function pointers resolved from the ICD. */
+static PFN_vkGetInstanceProcAddr p_vkGetInstanceProcAddr;
+
+/* Lazily loaded per-instance/device function pointers. */
+static PFN_vkCreateAndroidSurfaceKHR
+    p_vkCreateAndroidSurfaceKHR;
+static PFN_vkGetAndroidHardwareBufferPropertiesANDROID
+    p_vkGetAndroidHardwareBufferPropertiesANDROID;
+static PFN_vkGetMemoryAndroidHardwareBufferANDROID
+    p_vkGetMemoryAndroidHardwareBufferANDROID;
+static PFN_vkGetSemaphoreFdKHR
+    p_vkGetSemaphoreFdKHR;
+static PFN_vkImportSemaphoreFdKHR
+    p_vkImportSemaphoreFdKHR;
+
+/* ------------------------------------------------------------------ *
+ *  NDK symbol resolution                                              *
+ * ------------------------------------------------------------------ */
+
+/*
+ * android_resolve_sc_syms - dlopen libandroid.so and resolve every
+ * ASurfaceControl / AHardwareBuffer / AChoreographer symbol we need.
+ *
+ * Called once from get_vulkan_driver().  Returns FALSE if any mandatory
+ * symbol is missing (device is < API 29).
+ */
+BOOL android_resolve_sc_syms(void)
+{
+    void *lib;
+    int   api;
+
+    if (sc_funcs.available)
+        return TRUE;
+
+    api = android_get_device_api_level();
+    TRACE("device API level %d\n", api);
+
+    if (api < 29)
+    {
+        WARN("API %d < 29; ASurfaceControl path unavailable, "
+             "falling back to ANativeWindow.\n", api);
+        return FALSE;
+    }
+
+    lib = dlopen("libandroid.so", RTLD_NOW | RTLD_GLOBAL);
+    if (!lib)
+    {
+        ERR("dlopen(libandroid.so) failed: %s\n", dlerror());
+        return FALSE;
+    }

+/* Helper macro: resolve one symbol; return FALSE on failure. */
+#define RESOLVE(name)                                               \
+    do {                                                            \
+        sc_funcs.name = dlsym(lib, #name);                         \
+        if (!sc_funcs.name) {                                       \
+            ERR("dlsym(" #name "): %s\n", dlerror());              \
+            dlclose(lib);                                           \
+            return FALSE;                                           \
+        }                                                           \
+    } while (0)
+
+/* Helper macro: resolve optional symbol (API 30/31+); log but continue. */
+#define RESOLVE_OPT(name)                                           \
+    do {                                                            \
+        sc_funcs.name = dlsym(lib, #name);                         \
+        if (!sc_funcs.name)                                         \
+            WARN("Optional symbol " #name " not found (API %d)\n", api); \
+    } while (0)
+
+    /* Mandatory (API 29) */
+    RESOLVE(ASurfaceControl_createFromWindow);
+    RESOLVE(ASurfaceControl_create);
+    RESOLVE(ASurfaceControl_release);
+    RESOLVE(ASurfaceTransaction_create);
+    RESOLVE(ASurfaceTransaction_delete);
+    RESOLVE(ASurfaceTransaction_apply);
+    RESOLVE(ASurfaceTransaction_setBuffer);
+    RESOLVE(ASurfaceTransaction_setGeometry);
+    RESOLVE(ASurfaceTransaction_setVisibility);
+    RESOLVE(ASurfaceTransaction_setZOrder);
+    RESOLVE(ASurfaceTransaction_setOnComplete);
+    RESOLVE(ASurfaceTransactionStats_getLatchTime);
+    RESOLVE(ASurfaceTransactionStats_getPresentFenceFd);
+    RESOLVE(ASurfaceTransactionStats_getReleaseFenceFd);
+    RESOLVE(AHardwareBuffer_allocate);
+    RESOLVE(AHardwareBuffer_release);
+    RESOLVE(AHardwareBuffer_describe);
+    RESOLVE(AChoreographer_getInstance);
+    RESOLVE(AChoreographer_getFrameDeadline);
+
+    /* Optional (API 30+) */
+    RESOLVE_OPT(AChoreographer_postVsyncCallback);
+
+    /* Optional (API 31+) */
+    RESOLVE_OPT(ASurfaceTransaction_setFrameTimeline);
+    RESOLVE_OPT(ASurfaceTransaction_setOnCommit);
+
+#undef RESOLVE
+#undef RESOLVE_OPT
+
+    sc_funcs.available = TRUE;
+    TRACE("ASurfaceControl symbols resolved successfully.\n");
+    return TRUE;
+}
+
+/* ------------------------------------------------------------------ *
+ *  Helper: surface list lookup                                        *
+ * ------------------------------------------------------------------ */
+
+static struct wine_vk_surface *surface_from_hwnd(HWND hwnd)
+{
+    struct wine_vk_surface *s;
+
+    pthread_mutex_lock(&surface_list_lock);
+    LIST_FOR_EACH_ENTRY(s, &surface_list, struct wine_vk_surface, entry)
+    {
+        if (s->hwnd == hwnd)
+        {
+            pthread_mutex_unlock(&surface_list_lock);
+            return s;
+        }
+    }
+    pthread_mutex_unlock(&surface_list_lock);
+    return NULL;
+}
+
+/* ------------------------------------------------------------------ *
+ *  Driver entry points (stubs — implemented in later patches)         *
+ * ------------------------------------------------------------------ */
+
+static VkResult android_vulkan_surface_create(HWND hwnd,
+        VkInstance instance, VkSurfaceKHR *surface)
+{
+    FIXME("hwnd %p, instance %p — stub\n", hwnd, (void *)instance);
+    return VK_ERROR_EXTENSION_NOT_PRESENT;
+}
+
+static void android_vulkan_surface_destroy(HWND hwnd, VkSurfaceKHR surface)
+{
+    FIXME("hwnd %p — stub\n", hwnd);
+}
+
+static void android_vulkan_surface_presented(HWND hwnd, VkResult result)
+{
+    /* called by winevulkan after each present; used for frame pacing */
+    TRACE("hwnd %p result %d\n", hwnd, result);
+}
+
+static VkBool32 android_vkGetPhysicalDeviceWin32PresentationSupportKHR(
+        VkPhysicalDevice dev, uint32_t queue_family)
+{
+    /* On Android every GPU queue supports presentation. */
+    return VK_TRUE;
+}
+
+static const char *android_get_host_surface_extension(void)
+{
+    return "VK_KHR_android_surface";
+}
+
+/* ------------------------------------------------------------------ *
+ *  Driver registration                                                *
+ * ------------------------------------------------------------------ */
+
+static const struct vulkan_driver_funcs android_vulkan_driver_funcs =
+{
+    .p_vulkan_surface_create    = android_vulkan_surface_create,
+    .p_vulkan_surface_destroy   = android_vulkan_surface_destroy,
+    .p_vulkan_surface_presented = android_vulkan_surface_presented,
+    .p_vkGetPhysicalDeviceWin32PresentationSupportKHR =
+        android_vkGetPhysicalDeviceWin32PresentationSupportKHR,
+    .p_get_host_surface_extension = android_get_host_surface_extension,
+};
+
+const struct vulkan_driver_funcs *get_vulkan_driver(UINT version)
+{
+    if (version != WINE_VULKAN_DRIVER_VERSION)
+    {
+        ERR("version mismatch: driver %u, caller %u\n",
+            WINE_VULKAN_DRIVER_VERSION, version);
+        return NULL;
+    }
+
+    /* Best-effort symbol resolution; failure is non-fatal here.
+     * Surface creation will fall back to ANativeWindow if unavailable. */
+    android_resolve_sc_syms();
+
+    return &android_vulkan_driver_funcs;
+}
+
