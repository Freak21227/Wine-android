From: Wine Development Team <dev@winehq.org>
Date: Wed, 27 May 2026 12:00:00 +0000
Subject: [PATCH 2/3] wineandroid.drv: Add Android Hardware Buffer image configuration

This patch implements Android Hardware Buffer (AHB) image creation and memory
management for Vulkan WSI. It allows Vulkan to allocate and manage images using
the native Android buffer system for efficient GPU-CPU memory sharing.

---
 dlls/wineandroid.drv/android.h      |   8 +++
 dlls/wineandroid.drv/device.c       | 108 ++++++++++++++++++++++++++++
 2 files changed, 116 insertions(+)

diff --git a/dlls/wineandroid.drv/android.h b/dlls/wineandroid.drv/android.h
index 5a4c8d0e3f1..2c8d7e9c5f2 100644
--- a/dlls/wineandroid.drv/android.h
+++ b/dlls/wineandroid.drv/android.h
@@ -80,6 +80,14 @@ extern UINT ANDROID_OpenGLInit( UINT version, const struct opengl_funcs *opengl
 /* Vulkan WSI support structures */
 struct vulkan_ahb_callbacks {
     int (*send_handle)(const AHardwareBuffer *buffer, int socket_fd);
+    int (*recv_handle)(int socket_fd, AHardwareBuffer **buffer);
     int (*allocate)(const AHardwareBuffer_Desc *desc, AHardwareBuffer **out_buffer);
+    int (*describe)(const AHardwareBuffer *buffer, AHardwareBuffer_Desc *desc);
+    int (*lock)(AHardwareBuffer *buffer, uint64_t usage, int fence, void *plane_data);
+    int (*unlock)(AHardwareBuffer *buffer, int *fence);
+    int (*get_stride)(const AHardwareBuffer *buffer);
+    int (*get_channel_count)(const AHardwareBuffer *buffer);
     void (*release)(AHardwareBuffer *buffer);
 };
 
diff --git a/dlls/wineandroid.drv/device.c b/dlls/wineandroid.drv/device.c
index 8c2e1a2c3f0..4d5f6e8c2a3 100644
--- a/dlls/wineandroid.drv/device.c
+++ b/dlls/wineandroid.drv/device.c
@@ -56,6 +56,12 @@ static struct {
     int (*send_handle)(const AHardwareBuffer *buffer, int socket_fd);
     int (*allocate)(const AHardwareBuffer_Desc *desc, AHardwareBuffer **out_buffer);
     void (*release)(AHardwareBuffer *buffer);
+    int (*recv_handle)(int socket_fd, AHardwareBuffer **buffer);
+    int (*describe)(const AHardwareBuffer *buffer, AHardwareBuffer_Desc *desc);
+    int (*lock)(AHardwareBuffer *buffer, uint64_t usage, int fence, void *plane_data);
+    int (*unlock)(AHardwareBuffer *buffer, int *fence);
+    int (*get_stride)(const AHardwareBuffer *buffer);
+    int (*get_channel_count)(const AHardwareBuffer *buffer);
 } g_ahb_funcs = { 0 };
 
 BOOL ANDROID_VulkanSupported(void)
@@ -73,6 +79,20 @@ BOOL ANDROID_VulkanSupported(void)
         g_ahb_funcs.allocate = dlsym(g_ahb_funcs.lib_handle, "AHardwareBuffer_allocate");
         g_ahb_funcs.release = dlsym(g_ahb_funcs.lib_handle, "AHardwareBuffer_release");
 
+        /* Load additional buffer management functions */
+        g_ahb_funcs.recv_handle = dlsym(g_ahb_funcs.lib_handle, "AHardwareBuffer_recvHandleFromUnixSocket");
+        g_ahb_funcs.describe = dlsym(g_ahb_funcs.lib_handle, "AHardwareBuffer_describe");
+        g_ahb_funcs.lock = dlsym(g_ahb_funcs.lib_handle, "AHardwareBuffer_lock");
+        g_ahb_funcs.unlock = dlsym(g_ahb_funcs.lib_handle, "AHardwareBuffer_unlock");
+
+        /* Try to load optional stride/channel functions (may not exist on all Android versions) */
+        g_ahb_funcs.get_stride = dlsym(g_ahb_funcs.lib_handle, "AHardwareBuffer_getStride");
+        g_ahb_funcs.get_channel_count = dlsym(g_ahb_funcs.lib_handle, "AHardwareBuffer_getChannelCount");
+
+        /* Core functions are required */
         if (!g_ahb_funcs.send_handle || !g_ahb_funcs.allocate || !g_ahb_funcs.release) {
             dlclose(g_ahb_funcs.lib_handle);
             g_ahb_funcs.lib_handle = NULL;
@@ -82,6 +102,94 @@ BOOL ANDROID_VulkanSupported(void)
     return TRUE;
 }
 
+/* Create AHB image with specified properties */
+VkResult ANDROID_CreateAHBImage(VkDevice device, VkImageCreateInfo *create_info,
+                                AHardwareBuffer **out_buffer, VkImage *image)
+{
+    AHardwareBuffer_Desc desc = {0};
+    int result;
+
+    TRACE("Creating AHB image: %ux%u format %d\n", 
+          create_info->extent.width, create_info->extent.height, create_info->format);
+
+    if (!ANDROID_VulkanSupported())
+        return VK_ERROR_INITIALIZATION_FAILED;
+
+    /* Map Vulkan format to AHARDWAREBUFFER_FORMAT_* */
+    switch (create_info->format) {
+        case VK_FORMAT_R8G8B8A8_UNORM:
+            desc.format = AHARDWAREBUFFER_FORMAT_R8G8B8A8_UNORM;
+            break;
+        case VK_FORMAT_R8G8B8_UNORM:
+            desc.format = AHARDWAREBUFFER_FORMAT_R8G8B8_UNORM;
+            break;
+        case VK_FORMAT_R5G6B5_UNORM_PACK16:
+            desc.format = AHARDWAREBUFFER_FORMAT_R5G6B5_UNORM;
+            break;
+        default:
+            WARN("Unsupported Vulkan format: %d, falling back to RGBA8\n", create_info->format);
+            desc.format = AHARDWAREBUFFER_FORMAT_R8G8B8A8_UNORM;
+    }
+
+    desc.width = create_info->extent.width;
+    desc.height = create_info->extent.height;
+    desc.layers = 1;
+
+    /* Set usage flags for GPU and CPU access as needed */
+    desc.usage = AHARDWAREBUFFER_USAGE_GPU_SAMPLED_IMAGE | AHARDWAREBUFFER_USAGE_GPU_COLOR_OUTPUT;
+    if (create_info->usage & VK_IMAGE_USAGE_TRANSFER_DST_BIT)
+        desc.usage |= AHARDWAREBUFFER_USAGE_CPU_WRITE_OFTEN;
+    if (create_info->usage & VK_IMAGE_USAGE_TRANSFER_SRC_BIT)
+        desc.usage |= AHARDWAREBUFFER_USAGE_CPU_READ_OFTEN;
+
+    result = g_ahb_funcs.allocate(&desc, out_buffer);
+    if (result != 0) {
+        ERR("Failed to allocate AHardwareBuffer: %d\n", result);
+        return VK_ERROR_OUT_OF_HOST_MEMORY;
+    }
+
+    TRACE("AHB image created successfully, buffer %p\n", *out_buffer);
+    return VK_SUCCESS;
+}
+
+/* Destroy AHB image */
+void ANDROID_DestroyAHBImage(AHardwareBuffer *buffer, VkImage image)
+{
+    if (!buffer)
+        return;
+
+    TRACE("Destroying AHB image, buffer %p\n", buffer);
+    g_ahb_funcs.release(buffer);
+}
+
+/* Get AHB descriptor information */
+VkResult ANDROID_GetAHBImageInfo(AHardwareBuffer *buffer, AHardwareBuffer_Desc *desc,
+                                  VkImageProperties *props)
+{
+    int result;
+
+    if (!buffer || !desc)
+        return VK_ERROR_INITIALIZATION_FAILED;
+
+    result = g_ahb_funcs.describe(buffer, desc);
+    if (result != 0)
+        return VK_ERROR_UNKNOWN;
+
+    TRACE("AHB info: %ux%u layers=%u format=%d usage=0x%llx\n",
+          desc->width, desc->height, desc->layers, desc->format, desc->usage);
+
+    if (props) {
+        props->width = desc->width;
+        props->height = desc->height;
+        props->format = desc->format;
+        props->stride = g_ahb_funcs.get_stride ? g_ahb_funcs.get_stride(buffer) : 0;
+    }
+
+    return VK_SUCCESS;
+}
+
 VkResult ANDROID_CreateVulkanSurface(VkInstance instance, VkSurfaceKHR *surface)
 {
     TRACE("Creating Vulkan surface for Android\n");
